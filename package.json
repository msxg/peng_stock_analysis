{
  "name": "peng-stock-analysis",
  "version": "1.0.0",
  "description": "Node.js + Express 股票分析系统（重构版）",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "PORT=8889 HOST=127.0.0.1 nodemon src/server.js",
    "dev:web": "BACKEND_ORIGIN=http://127.0.0.1:8889 next dev --webpack -p 8888",
    "dev:legacy": "PORT=8889 HOST=127.0.0.1 nodemon src/server.js",
    "build": "next build --webpack",
    "start": "concurrently -k \"npm:start:api\" \"npm:start:web\"",
    "start:api": "PORT=8889 HOST=127.0.0.1 node src/server.js",
    "start:web": "BACKEND_ORIGIN=http://127.0.0.1:8889 next start -p 8888",
    "start:legacy": "PORT=8889 HOST=127.0.0.1 node src/server.js",
    "lint": "echo 'Use next lint or biome based on your preference'",
    "test": "node --test",
    "test:e2e:focus-news": "node scripts/focus-news-ui-e2e.mjs"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.91.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "autoprefixer": "^10.4.27",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.577.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.2",
    "next": "^16.2.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^6.9.15",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "playwright": "^1.58.2"
  }
}
